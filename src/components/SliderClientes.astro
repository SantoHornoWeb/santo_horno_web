---
const clients = [
  { name: "LOMITERIA POPULAR - CORDOBA", logo: "./clientes/lomiteria_popular.png" },
  { name: "HOYTS - CORDOBA", logo: "./clientes/hoyts.png" },
  { name: "MOSTACHYS - CORDOBA", logo: "./clientes/mostachys.png" },
  // { name: "LA PANCHE - CORDOBA", logo: "./clientes/lomiteria_popular.png" }, //falta
  // { name: "TORNEO GOLDEN- CORDOBA", logo: "./clientes/lomiteria_popular.png" }, //falta
  { name: "STREGA - CORDOBA", logo: "./clientes/strega.png" },
  { name: "MONTAGU - CORDOBA", logo: "./clientes/montagu.png" },
  { name: "ANTARES - CORDOBA", logo: "./clientes/antares.png" },
  { name: "COLORES SANTOS - CORDOBA", logo: "./clientes/colores_santos.png" },
  { name: "THE JOURNEY - CORDOBA", logo: "./clientes/journey.png" },
  // { name: "COMBI - CORDOBA", logo: "./clientes/lomiteria_popular.png" }, //falta
  // { name: "DON RUFFINO - CORDOBA", logo: "./clientes/lomiteria_popular.png" }, //falta
  // { name: "MAMANU - CORDOBA", logo: "./clientes/lomiteria_popular.png" }, //falta
  { name: "WYOMING - CORDOBA", logo: "./clientes/wyoming.png" },
  // { name: "LOMITOS 22 - CORDOBA", logo: "./clientes/lomiteria_popular.png" }, //falta
  // { name: "LA PLAZA - CORDOBA", logo: "./clientes/lomiteria_popular.png" }, //falta
  // { name: "VILLA BURGUESA - CARLOS PAZ", logo: "./clientes/lomiteria_popular.png" }, //falta
  // { name: "QUE LOMOS - ALTA GRACIA", logo: "./clientes/lomiteria_popular.png" }, //falta
];
---

<div class="clients-slider-wrapper">
  <!-- Línea decorativa superior -->
  <div class="slider-accent-line slider-accent-line--top"></div>

  <div class="clients-slider">
    <div class="slider-track">
      {clients.concat(clients).map((client, index) => (
        <div class="client-item" key={index}>
          <img 
            src={client.logo} 
            alt={`Logo de ${client.name}`} 
            loading="lazy"
          />
          <span class="client-name">{client.name}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Línea decorativa inferior -->
  <div class="slider-accent-line slider-accent-line--bottom"></div>
</div>

<style>
  /* ── Contenedor Principal (Wrapper) ── */
  .clients-slider-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: var(--border-radius-lg);
    background: var(--color-white);
    box-shadow: var(--shadow-sm);
  }

  /* ── Líneas Decorativas Animadas ── */
  .slider-accent-line {
    height: 3px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-secondary) 20%,
      var(--color-primary) 50%,
      var(--color-secondary) 80%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: line-shimmer 4s ease infinite;
  }

  @keyframes line-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Slider con Efecto Fade Lateral (Mask-Image) ── */
  .clients-slider {
    overflow: hidden;
    padding: var(--spacing-md) 0;
    /* Difumina los bordes izquierdo y derecho para que los logos "aparezcan" y "desaparezcan" suavemente */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
  }

  .slider-track {
    display: flex;
    animation: scroll 30s linear infinite;
    gap: var(--spacing-lg);
  }

  /* Pausar la animación cuando el usuario hace hover en todo el contenedor */
  .clients-slider-wrapper:hover .slider-track {
    animation-play-state: paused;
  }

  .client-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
    min-width: 150px;
    padding: var(--spacing-sm);
    transition: var(--transition);
    cursor: pointer;
  }

  .client-item:hover {
    transform: translateY(-5px);
  }

  .client-item img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 50%;
    filter: grayscale(100%);
    transition: transform 0.4s ease, filter 0.4s ease, box-shadow 0.4s ease;
    box-shadow: var(--shadow-sm);
  }

  .client-item:hover img {
    filter: grayscale(0%);
    transform: scale(1.1);
    box-shadow: 0 6px 15px rgba(139, 90, 60, 0.3); /* Sombra elegante */
  }

  .client-name {
    font-size: 0.8rem; /* Un poco más pequeño y sutil */
    font-weight: 600; /* Un poco más grueso */
    color: var(--color-primary);
    text-align: center;
    opacity: 0.6; /* Más apagado por defecto */
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: var(--transition);
  }

  .client-item:hover .client-name {
    opacity: 1; /* Se enciende al hover */
    color: var(--color-secondary);
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }


  @media (max-width: 768px) {
    .slider-track {
      animation-duration: 20s;
      gap: var(--spacing-md);
    }
    
    .client-item {
      min-width: 120px;
    }
    
    .client-item img {
      width: 60px;
      height: 60px;
    }
    
    .client-name {
      font-size: 0.75rem;
    }
    
    /* Ajustar el fade en móviles si es necesario */
    .clients-slider {
        -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
        mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    }
  }
</style>