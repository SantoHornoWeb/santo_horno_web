---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import BlogCard from '../components/BlogCard.astro';
import SliderClientes from '../components/SliderClientes.astro';
import '../styles/global.css';
---

<Layout title="Santo Horno - Panificadora Profesional">

  <Header />
  
  <main>
    <!-- Hero Section -->
    <section id="inicio" class="hero">
      <div class="hero-content">
        <div class="container">
          <div class="hero-text fade-in">
            <h1>
              <span class="logo-script">Panificados para gastronomía</span>
            </h1>
            <h2 class="hero-subtitle">Elaboramos panes de alta calidad para cocinas que exigen lo mejor.</h2>
            <p class="hero-description">
              Somos una empresa familiar con foco en la excelencia, la eficiencia y las relaciones a largo plazo. 
              En Santo Horno elaboramos panes para hamburguesas, lomitos y más, con procesos cuidados y sabores consistentes, es por eso que nos eligen restaurantes y marcas líderes en Córdoba.
            </p>
            <div class="hero-buttons">
              <a href="#productos" class="btn">Ver productos</a>
              <a href="#contacto" class="btn btn-secondary">Contactar</a>
            </div>
          </div>
        </div>
      </div>
      <div class="hero-image">
        <img src="./hero/imagen-hero2.jpeg" 
             alt="Panadería artesanal" 
             loading="eager" />
      </div>
    </section>

    <!-- Ticker Strip -->
    <div class="ticker-strip" aria-hidden="true">
      <div class="ticker-track">
        <!-- Grupo 1 -->
        <div class="ticker-group">
          <span>Pan de Hamburguesa</span><span class="ticker-dot">•</span>
          <span>Pan de Lomito</span><span class="ticker-dot">•</span>
          <span>Pan de Choripán</span><span class="ticker-dot">•</span>
          <span>Pan de Pizza</span><span class="ticker-dot">•</span>
          <span>Pan de Pebete</span><span class="ticker-dot">•</span>
          <span>Pan de Papa</span><span class="ticker-dot">•</span>
          <span>Pan de Milanesa</span><span class="ticker-dot">•</span>
          <span>Pan de Pancho</span><span class="ticker-dot">•</span>
        </div>
        <!-- Grupo 2 -->
        <div class="ticker-group">
          <span>Pan de Hamburguesa</span><span class="ticker-dot">•</span>
          <span>Pan de Lomito</span><span class="ticker-dot">•</span>
          <span>Pan de Choripán</span><span class="ticker-dot">•</span>
          <span>Pan de Pizza</span><span class="ticker-dot">•</span>
          <span>Pan de Pebete</span><span class="ticker-dot">•</span>
          <span>Pan de Papa</span><span class="ticker-dot">•</span>
          <span>Pan de Milanesa</span><span class="ticker-dot">•</span>
          <span>Pan de Pancho</span><span class="ticker-dot">•</span>
        </div>
        <!-- Grupo 3 -->
        <div class="ticker-group">
          <span>Pan de Hamburguesa</span><span class="ticker-dot">•</span>
          <span>Pan de Lomito</span><span class="ticker-dot">•</span>
          <span>Pan de Choripán</span><span class="ticker-dot">•</span>
          <span>Pan de Pizza</span><span class="ticker-dot">•</span>
          <span>Pan de Pebete</span><span class="ticker-dot">•</span>
          <span>Pan de Papa</span><span class="ticker-dot">•</span>
          <span>Pan de Milanesa</span><span class="ticker-dot">•</span>
          <span>Pan de Pancho</span><span class="ticker-dot">•</span>
        </div>
      </div>
    </div>

    <!-- Nosotros Section -->
    <section id="nosotros" class="section bg-light">
      <div class="container">
        <h2 class="section-title fade-in">Nosotros</h2>
        
        <div class="about-intro fade-in">
          <div class="about-text">
            <h3 style="font-family: var(--font-secondary);">¿Quienes somos?</h3>
            <p>
             <span style="font-weight: 700; font-family: var(--font-body); font-weight: bold;">Santo Horno</span> es una empresa familiar fundada en el año 2015, dedicada a la fabricación de panes para gastronomía.
            </p>
            <p>
              Contamos con un equipo de alrededor de 25 colaboradores, entre empleados directos e indirectos, que trabaja cada día con compromiso y pasión. Nuestra línea de productos incluye una amplia variedad de panes: para lomito u otros sándwiches, para hamburguesa, para choripán, para pata, para milanesa, para pebete y pancho y masas de pizza estilo casero.
            </p>
            <p>
              En Santo Horno, nos enfocamos en ofrecer productos de calidad, sabrosos y confiables, elaborados con materias primas seleccionadas y procesos cuidados.
              Fomentamos un buen ambiente de trabajo basado en el respeto, la colaboración y la confianza. Además, cultivamos relaciones transparentes con nuestros clientes, a través de una comunicación abierta, clara y respetuosa.
            </p>
          </div>
          <div class="about-image">
            <img src="./nosotros/imagen-nosotros.png" 
                 alt="Nuestro equipo" loading="lazy" />
          </div>
        </div>

        <!-- Stats counter row -->
        <div class="stats-row fade-in">

          <div class="stat-item" data-target="10" data-suffix="+ años">
            <span class="stat-number" id="stat-anios">0</span>
            <span class="stat-label">Años en el rubro</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item" data-target="150" data-suffix="+ clientes">
            <span class="stat-number" id="stat-clientes">0</span>
            <span class="stat-label">Clientes activos</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item" data-target="14" data-suffix=" productos">
            <span class="stat-number" id="stat-productos">0</span>
            <span class="stat-label">Variedades de pan</span>
          </div>
        </div>

        <div class="values-grid grid grid-3">

          <!-- Misión -->
          <div class="value-card fade-in">
            <div class="value-card-image">
              <img src="./santo_horno/mision.jpeg" alt="Misión" />
              <div class="value-card-img-overlay"></div>

            </div>
            <div class="value-card-body">
              <h4>Misión</h4>
              <p>Hacer los panes más ricos, de mejor calidad y a un buen precio, autosuperándonos día a día y trabajando con profesionalismo para lograr la satisfacción de nuestros clientes, generando una relación a largo plazo.</p>
            </div>
          </div>

          <!-- Visión -->
          <div class="value-card fade-in">
            <div class="value-card-image">
              <img src="./santo_horno/vision.jpeg" alt="Visión" />
              <div class="value-card-img-overlay"></div>

            </div>
            <div class="value-card-body">
              <h4>Visión</h4>
              <p>Ser una empresa líder en producción y comercialización de panes para gastronomía, llegando a los mercados más rentables donde nos podamos desarrollar.</p>
            </div>
          </div>

          <!-- Valores -->
          <div class="value-card fade-in">
            <div class="value-card-image">
              <img src="./santo_horno/valores.jpeg" alt="Valores" />
              <div class="value-card-img-overlay"></div>

            </div>
            <div class="value-card-body">
              <h4>Valores</h4>
              <ul class="value-list">
                <li>Salud</li>
                <li>Transparencia</li>
                <li>Honestidad</li>
                <li>Compromiso</li>
                <li>Eficiencia</li>
              </ul>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Productos Section -->
    <section id="productos" class="section">
      <div class="wave-divider wave-top-light" aria-hidden="true">
        <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
          <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="shape-fill"></path>
        </svg>
      </div>
      <div class="container">
        <h2 class="section-title fade-in">Nuestros Productos</h2>
        <div class="products-grid grid grid-3">
          <ProductCard 
            name="PAN DE LOMO TRADICIONAL"
            image="./productos/pan_lomo_tradicional.png"
            size="Bolsa de 12 unidades"
            descriptionItems={[
              "Tamaño chico 18cm",
              "Tamaño mediano 20cm",
              "Tamaño grande 22cm",
            ]}
            lockTitleHeight={3.25}
            category="Pan"
          />
          <ProductCard 
            name="PAN DE PIZZA PARA LOMO"
            image="./productos/pan_pizza_para_lomo.jpeg"
            size="Bolsa de 12 unidades"
            descriptionItems={["Tamaño mediano 19cm"]}
            lockTitleHeight={3.25}
            category="Pan"
          />
          
          <ProductCard 
            name="PAN DE HAMBURGUESA TIPO VIENA CON SEMILLAS"
            image="./productos/pan_hamburguesa_tipo_viena.png?auto=compress&cs=tinysrgb&w=400"
            size="Bolsa de 12 unidades"
            descriptionItems={["Tamaño grande 12cm"]}
            lockTitleHeight={3.25}
            category="Pan"
          />


          <ProductCard 
            name="PAN RUSTICO"
            image="./productos/pan_hamburguesa_rustico.png?auto=compress&cs=tinysrgb&w=400"
            size="Bolsa de 12 unidades"
            descriptionItems={["Tamaño grande 12cm"]}
            lockTitleHeight={3.35}
            category="Pan"
          />
          
          <ProductCard 
            name="PAN DE PAPA"
            image="./productos/pan_papa.jpeg?auto=compress&cs=tinysrgb&w=400"
            size="Bolsa de 12 unidades"
            descriptionItems={[
              "Tamaño chico 9cm",
              "Tamaño grande 12cm",
            ]}
            lockTitleHeight={2.25}
            category="Pan"
          />

          <ProductCard 
            name="PAN DE PAPA CON QUESO"
            image="./productos/pan_papa_queso.png?auto=compress&cs=tinysrgb&w=400"
            size="Bolsa de 12 unidades"
            descriptionItems={["Tamaño grande 12cm"]}
            lockTitleHeight={2.25}
            category="Pan"
          />
          
          <ProductCard 
            name="PAN DE PAPA CON SEMILLAS"
            image="./productos/pan_papa_semilla.png?auto=compress&cs=tinysrgb&w=400"
            size="Bolsa de 12 unidades"
            descriptionItems={["Tamaño grande 12cm"]}
            lockTitleHeight={2.25}
            category="Pan"
          />
          
          <ProductCard 
            name="PAN DE CHORI"
            image="./productos/pan_chori.png?auto=compress&cs=tinysrgb&w=400"
            size="Bolsa de 12 unidades"
            descriptionItems={["Tamaño 16cm"]}
            category="Pan"
          />

          <ProductCard 
            name="PAN DE MILA"
            image="./productos/pan_mila.png?auto=compress&cs=tinysrgb&w=400"
            size="Bolsa de 12 unidades"
            descriptionItems={["Tamaño 22cm"]}
            category="Pan"
          />

          <ProductCard 
            name="PAN CHIP"
            image="./productos/pan_chip.png?auto=compress&cs=tinysrgb&w=400"
            size="Bolsa de 60 unidades"
            descriptionItems={["Tamaño 7cm"]}
            category="Pan"
          />

          <ProductCard 
            name="MASA DE PIZZA"
            image="./productos/masa_pizza.png?auto=compress&cs=tinysrgb&w=400"
            size="Bolsa de 10 unidades"
            descriptionItems={[
              "Tamaño mediana 30cm",
              "Tamaño grande 32cm",
            ]}
            category="Pan"
          />

          <ProductCard 
            name="MASA DE PIZZETA"
            image="./productos/masa_pizzeta.png?auto=compress&cs=tinysrgb&w=400"
            size="Bolsa de 10 unidades"
            descriptionItems={["Tamaño 20cm"]}
            category="Pan"
          />

          <ProductCard 
            name="PAN DE PEBETE O SUPERPANCHO CON SEMILLAS"
            image="./productos/pan_pebeton.png?auto=compress&cs=tinysrgb&w=400"
            size="Bolsa de 12 unidades"
            descriptionItems={["Tamaño 20cm"]}
            lockTitleHeight={3.45}
            category="Pan"
          />

          <ProductCard 
            name="PAN DE PEBETE O SUPERPANCHO "
            image="./productos/pan_pebeton_sin_semilla.png?auto=compress&cs=tinysrgb&w=400"
            size="Bolsa de 12 unidades"
            descriptionItems={["Tamaño 20cm"]}
            lockTitleHeight={3.45}
            category="Pan"
          />
        </div>
      </div>
    </section>

    <!-- Clientes Section -->
    <section id="clientes" class="section bg-light">
      <div class="wave-divider wave-top-white" aria-hidden="true">
        <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
          <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="shape-fill"></path>
        </svg>
      </div>
      <div class="container">
        <h2 class="section-title fade-in">Nuestros Clientes</h2>
        <p class="section-subtitle fade-in text-center">
          Confianza que crece día a día con nuestros clientes
        </p>
        
        <div class="fade-in">
          <SliderClientes />
        </div>
      </div>
    </section>

    <!-- Blog Section -->
    <section id="blog" class="section">
      <div class="wave-divider wave-top-light" aria-hidden="true">
        <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
          <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="shape-fill"></path>
        </svg>
      </div>
      <div class="container">
        <h2 class="section-title fade-in">Blog</h2>
        <p class="section-subtitle fade-in text-center">
          Novedades, recetas y curiosidades del mundo de la panadería
        </p>

        <div class="blog-grid grid grid-3">
          <BlogCard 
            title="Los secretos del pan artesanal"
            excerpt="En Panificadora Santo Horno, creemos que un buen pan no se improvisa: se trabaja todos los días, con compromiso, con técnica, y con respeto por lo que representa. ¿Querés conocer cómo trabajamos? Te lo contamos."
            image="./blog/pan_artesanal.jpeg"
            date="28 Jul 2025"
            category="Técnicas"
            fullContent={`
              <p>En <strong>Panificadora Santo Horno</strong>, creemos que un buen pan no se improvisa: se trabaja todos los días, con compromiso, con técnica, y con respeto por lo que representa.</p>
              
              <p><strong>¿Querés conocer cómo trabajamos? Te lo contamos.</strong></p>
              
              <h3 style="font-size: 1.5rem;">1. Ingredientes nobles</h3>
              <p>Usamos <strong>harina de calidad</strong>, <strong>agua pura</strong>, sal y aditivos naturales en cantidades mínimas, solo lo necesario para garantizar que nuestros productos lleguen frescos y en condiciones. Lo simple, bien hecho, siempre funciona.</p>
              
              <h3 style="font-size: 1.5rem;">2. Fermentación controlada</h3>
              <p>Nuestros panes fermentan en cámaras especiales, con temperatura y humedad reguladas. Esto nos permite mantener <strong>consistencia</strong>, sin resignar sabor ni textura.</p>
              
              <h3 style="font-size: 1.5rem;">3. Tecnología que acompaña, manos que hacen</h3>
              <p>Tenemos <strong>equipamiento industrial</strong> para garantizar volumen y seguridad alimentaria, pero nuestros panes no salen de una línea automática. Cada receta está pensada y ajustada por nuestros panaderos: que saben, que prueban, y que no se conforman.</p>
            `}
          />
          
          <BlogCard 
            title="Panes pensados para cada sándwich"
            excerpt="Sabemos que no hay buen sándwich sin buen pan. Por eso trabajamos con cocineros, bodegones, hamburgueserías, caterings y cervecerías, desarrollando productos que se adapten a cada tipo de preparación. Acá te dejamos una guía rápida para elegir el ideal"
            image="./blog/pan_para_cada_sandwich.jpeg"
            date="28 Jul 2025"
            category="Consejos"
            fullContent={`
              <p>Sabemos que no hay buen sándwich sin buen pan. Por eso trabajamos con cocineros, bodegones, hamburgueserías, caterings y cervecerías, desarrollando productos que se adapten a cada tipo de preparación. Acá te dejamos una guía rápida para elegir el ideal:</p>
              
              <h3 style="font-size: 1.5rem;">🥩 Para lomo</h3>
              <p><strong>Pan tipo francés sin corteza – en tres tamaños</strong></p>
              <p><strong>Grande (22 cm) / Mediano (20 cm) / Chico (18 cm)</strong></p>
              <p>Pan suave, con miga esponjosa y corteza fina. Acompaña sin romperse. Ideal para lomitos clásicos y sándwiches generosos.</p>
              
              <h3 style="font-size: 1.5rem;">🍔 Para hamburguesas</h3>
              <p><strong>Pan de Papa</strong> <em>(también con queso, con semillas y en versión chica de 9 cm)</em></p>
              <p>Textura tierna, humedad natural y un sabor que no compite con la carne. Elegido por hamburgueserías premium.</p>
              
              <p><strong>Pan Hamburguesa con lino y sésamo</strong></p>
              <p>Ideal para cartas clásicas o sliders. Suave, con semillas tostadas que suman sabor.</p>
              
              <p><strong>Pan Rústico (12 cm)</strong></p>
              <p>Corteza más firme, miga densa. Perfecto para hamburguesas más pesadas, con ingredientes intensos.</p>
              
              <h3 style="font-size: 1.5rem;">⭐ Panes especiales para ocasiones únicas</h3>
              <p><strong>Pan para un buen sandwich de Mila</strong> – Firme, alargado, estructura pensada para contener sin desarmarse un sandwich de milanesa con aderezo, lechuga, tomate, huevo y todo lo que quieras sumar!</p>
              
              <p><strong>Pan para Chori</strong> – Corteza fina, miga húmeda, ideal para parrilla. Para acompañar el mejor choripán. Un pan firme pero tierno.</p>
            `}
          />

          <BlogCard 
              title='Pan de pizza para sándwich'
              excerpt='Base crocante por fuera, miga húmeda por dentro: todo lo que hace grande a una pizza al molde, ahora en forma de pan para sándwich.'
              image='./blog/pan_pizza_nuevo.jpeg'
              date='28 Jul 2025'
              category='Producto Destacado'
              fullContent={`
                <p><strong>Ideal para:</strong></p>
                <ul>
                  <li>Sándwiches calientes tipo pizza rellena.</li>
                  <li>Provoleta, bondiola, panceta.</li>
                  <li>Jamón y queso con una buena mayo casera.</li>
                </ul>
                <p>Muy pronto estará disponible. ¿Querés probarlo antes que nadie? <strong>Escribinos y te sumamos a las pruebas.</strong></p>
              `}
          />
        
</div>
    </section>

    <!-- Ubicación Section -->
    <section id="ubicacion" class="section">
      <div class="container">
        <h2 class="section-title fade-in">Nuestras Ubicaciones</h2>
        <p class="section-subtitle fade-in text-center">
          Encontranos en nuestros dos puntos de atención en Córdoba
        </p>
        
        <div class="grid grid-2 fade-in" style="gap: 2rem; margin-top: var(--spacing-lg);">
          
          <!-- Local Venta al Público -->
          <div class="map-container" style="margin-top: 0;">
            <div class="map-wrapper map-wrapper-split">
              <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3404.2488873255093!2d-64.19763212325779!3d-31.434814397144432!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9432a28aa06a7341%3A0x73e62b40681d6fa4!2sAvenida%20V%C3%A9lez%20Sarsfield%201696!5e0!3m2!1ses!2sar!4v1775577054153!5m2!1ses!2sar" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
            <div class="map-info map-info-split">
              <div class="map-info-item">
                <svg width="42" height="42" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                </svg>
                <div>
                  <h4 class="map-title">Local Venta al Público</h4>
                  <p class="map-desc">Av. Vélez Sarsfield 1696, B° Güemes, Córdoba</p>
                </div>
              </div>
              <a href="https://maps.google.com/?q=Avenida+Vélez+Sarsfield+1696,+Córdoba" target="_blank" rel="noopener noreferrer" class="btn map-btn-split">
                Obtener indicaciones
              </a>
            </div>
          </div>

          <!-- Fábrica -->
          <div class="map-container" style="margin-top: 0;">
            <div class="map-wrapper map-wrapper-split">
              <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3403.6620168167537!2d-64.20004372325718!3d-31.450970397926266!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9432994dd17a3f43%3A0x6297b9e35ba0005b!2sPanificadora%20Santo%20Horno%3A%20Panes%20para%20gastronomia!5e0!3m2!1ses!2sar!4v1775573830211!5m2!1ses!2sar" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
            <div class="map-info map-info-split">
              <div class="map-info-item">
                <svg width="42" height="42" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                </svg>
                <div>
                  <h4 class="map-title text-secondary">Fábrica Principal</h4>
                  <p class="map-desc">Lautaro 150, B° Las Flores, Córdoba</p>
                </div>
              </div>
              <a href="https://www.google.com/maps?cid=7104351323346174043&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYASAA&hl=es&gl=AR&source=embed" target="_blank" rel="noopener noreferrer" class="btn btn-secondary map-btn-split">
                Obtener indicaciones
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Contacto Section -->
